Bootstrap: docker
From: python:3.8-slim

%labels
    Author Rui Wang
    Version 1.0.0
    Description VARIANT - Viral mutAtion trackeR aImed At GeNome and proTein-level

%environment
    export PYTHONPATH=/app
    export PYTHONUNBUFFERED=1
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%files
    requirements_web.txt /app/requirements_web.txt
    virus_config.yaml /app/virus_config.yaml

%post
    # Update package list and install system dependencies
    apt-get update && apt-get install -y \
        gcc \
        g++ \
        make \
        curl \
        wget \
        git \
        && rm -rf /var/lib/apt/lists/*

    # Install Python dependencies
    pip install --no-cache-dir -r /app/requirements_web.txt

    # Create necessary directories
    mkdir -p /app/static /app/templates /app/uploads /app/results /app/data /app/result /app/plot /app/logs

    # Set working directory
    cd /app

%runscript
    python /app/web_app.py

%startscript
    python /app/web_app.py
